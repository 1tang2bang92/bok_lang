Grammar

Rule 0     S' -> program
Rule 1     program -> block
Rule 2     block -> decls
Rule 3     decls -> decl
Rule 4     decls -> decls decl
Rule 5     decl -> statement
Rule 6     statement -> expression_statement
Rule 7     statement -> compound_statement
Rule 8     expression_statement -> expression
Rule 9     compound_statement -> LBRACE statement_list RBRACE
Rule 10    compound_statement -> LBRACE RBRACE
Rule 11    statement_list -> statement
Rule 12    statement_list -> statement_list statement
Rule 13    expression -> EXTERN FN ID prototype
Rule 14    expression -> FN ID prototype statement
Rule 15    prototype -> LPAREN RPAREN
Rule 16    prototype -> LPAREN param_list RPAREN
Rule 17    param_list -> param
Rule 18    param_list -> param_list COMMA param
Rule 19    param -> ID
Rule 20    expression -> expression ADD expression
Rule 21    expression -> expression MIN expression
Rule 22    expression -> expression MUL expression
Rule 23    expression -> expression DIV expression
Rule 24    expression -> expression EQ expression
Rule 25    expression -> expression NE expression
Rule 26    expression -> expression GT expression
Rule 27    expression -> expression LT expression
Rule 28    expression -> LET ID ASSIGN expression
Rule 29    expression -> LOOP statement
Rule 30    expression -> LOOP expression statement
Rule 31    expression -> ID ASSIGN expression
Rule 32    expression -> MIN expression
Rule 33    expression -> LPAREN expression RPAREN
Rule 34    expression -> NUMBER
Rule 35    expression -> ID
Rule 36    expression -> ID LPAREN RPAREN
Rule 37    expression -> ID LPAREN args RPAREN
Rule 38    args -> arg
Rule 39    args -> args COMMA arg
Rule 40    arg -> expression
Rule 41    expression -> IF expression statement
Rule 42    expression -> IF expression statement ELSE statement

